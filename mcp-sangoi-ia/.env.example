# Local-operator-only convenience default. Non-local/containerized/shared launches
# must set this explicitly and should fail closed until the real production auth path exists.
SANGOI_CODEX_RUNTIME_MODE=dev
SANGOI_CODEX_MCP_HOST=127.0.0.1
SANGOI_CODEX_MCP_PORT=7788
SANGOI_CODEX_TIMEOUT_MS=120000
SANGOI_CODEX_WORKDIR=/home/lucas/work/sangoi-ia
SANGOI_CODEX_MODEL=
